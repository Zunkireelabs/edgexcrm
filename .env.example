# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=https://leads-crm.zunkireelabs.com

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxx

# Google OAuth (for Gmail auto-forward)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Old RKU Supabase (for one-time migration only)
OLD_SUPABASE_URL=https://ldsgsdjixzsljgkcktqu.supabase.co
OLD_SUPABASE_SERVICE_ROLE_KEY=your-old-service-role-key

# AI SDK write-tool approval signing (experimental_toolApprovalSecret)
# AI_TOOL_APPROVAL_SECRET=  # 32+ random bytes (openssl rand -hex 32); HMAC-signs AI write-tool approvals. Required when AI_WRITE_TOOLS_ENABLED=true.

# Inngest (durable background jobs). Server-only runtime secrets — never NEXT_PUBLIC.
# Local dev: leave the keys unset, set INNGEST_DEV=1, and run `npx inngest-cli dev`.
# Stage/prod: keys are injected by the deploy pipelines; do NOT set INNGEST_DEV there.
INNGEST_DEV=1
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
